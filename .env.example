# Model Configuration
MODEL_TYPE=baseline  # Options: "baseline" or "bert"

# Data Paths
DATA_PATH=data/support_emails.csv
BASELINE_MODEL_PATH=models/baseline_classifier.pkl
BERT_MODEL_PATH=models/bert_classifier
BERT_LABEL_ENCODER_PATH=models/bert_label_encoder.pkl

# API Configuration
API_HOST=0.0.0.0  # Server binds to all interfaces - ACCESS via localhost/127.0.0.1
API_PORT=8000
API_RELOAD=True

# Logging Configuration
# LOG_LEVEL: 10=DEBUG, 20=INFO, 30=WARNING, 40=ERROR, 50=CRITICAL
LOG_LEVEL=20
LOG_FILE=logs/app.log
